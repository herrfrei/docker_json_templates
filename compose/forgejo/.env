# Forgejo configuration

# The port where Forgejo will be accessible
WEB_PORT=3000

# The port for SSH access (change if you want Forgejo to handle SSH)
SSH_PORT=2222

# Data location for persistent storage
DATA_LOCATION=./forgejo/data

# Log location
LOG_LOCATION=./forgejo/logs

# Forgejo version
FORGEJO_VERSION=9

# Timezone
TZ=Etc/UTC
