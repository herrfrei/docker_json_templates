# Paperless-ngx environment variables for MOS
# 
# For more information about these settings, visit:
# https://docs.paperless-ngx.com/configuration/

# ============================================================================
# STORAGE LOCATIONS
# ============================================================================

# The location where your uploaded documents are stored
PAPERLESS_DATA=./data

# The location where your media files (documents, previews) are stored
PAPERLESS_MEDIA=./media

# The location where exported documents are stored
PAPERLESS_EXPORT=./export

# The location where documents to be consumed (auto-import) are stored
PAPERLESS_CONSUME=./consume

# The location where database files are stored
PAPERLESS_DB=./db

# The location where redis data are stored
PAPERLESS_REDIS=./redis

# ============================================================================
# PAPERLESS VERSION AND URL
# ============================================================================

# Paperless version to use (recommended: use a specific version tag, not 'latest')
PAPERLESS_VERSION=2.17

# The URL where paperless will be accessible (auto-filled by MOS with [ADDRESS]:[PORT])
# For custom URL, uncomment and edit:
# PAPERLESS_URL=http://[ADDRESS]:[PORT:8050]

# ============================================================================
# SECURITY
# ============================================================================

# The secret key for paperless (generate with: python -c 'import secrets; print(secrets.token_hex(64))')
# This should be a long random string when exposing paperless publicly
# For local use, the default value is sufficient but you should change it
PAPERLESS_SECRET_KEY=change-me-generate-a-random-key

# ============================================================================
# LOCALIZATION
# ============================================================================

# The timezone for paperless (must be a valid IANA timezone identifier)
PAPERLESS_TIME_ZONE=UTC

# The default language to use for OCR
# Common values: eng (English), deu (German), fra (French), spa (Spanish)
PAPERLESS_OCR_LANGUAGE=eng

# ============================================================================
# DATABASE SETTINGS
# ============================================================================

# PostgreSQL connection settings
POSTGRES_DB=paperless
POSTGRES_USER=paperless
POSTGRES_PASSWORD=paperless

# ============================================================================
# USER MAPPING
# ============================================================================

# The UID and GID for the paperless user inside the container
# Set to your host user's UID/GID for proper file permissions
# Default values are for standard Linux systems
USERMAP_UID=1000
USERMAP_GID=1000
