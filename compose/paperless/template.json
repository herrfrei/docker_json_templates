{
  "name": "paperless-ngx",
  "category": ["productivity", "document-management"],
  "description": "Paperless-ngx is a document management system that transforms your loose documents into a searchable, indexed, and organized collection. It includes OCR, metadata extraction, and web-based access.",
  "website": "https://docs.paperless-ngx.com/",
  "icon": "https://cdn.jsdelivr.net/gh/paperless-ngx/paperless-ngx@main/assets/logo/web/svg/paperless-logo-icon.svg",
  "support": "https://github.com/paperless-ngx/paperless-ngx/issues",
  "web_ui_url": "http://[ADDRESS]:[PORT:8050]/",
  "port_mapping": {
    "8050": "8000"
  },
  "volume_mapping": {
    "data": "PAPERLESS_DATA",
    "media": "PAPERLESS_MEDIA",
    "export": "PAPERLESS_EXPORT",
    "consume": "PAPERLESS_CONSUME",
    "db": "PAPERLESS_DB",
    "redis": "PAPERLESS_REDIS"
  }
}
